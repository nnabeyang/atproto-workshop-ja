{
  "id": "app.bsky.feed.describeFeedGenerator",
  "defs": {
    "feed": {
      "type": "object",
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "at-uri"
        }
      }
    },
    "main": {
      "type": "query",
      "output": {
        "schema": {
          "type": "object",
          "required": [
            "did",
            "feeds"
          ],
          "properties": {
            "did": {
              "type": "string",
              "format": "did"
            },
            "feeds": {
              "type": "array",
              "items": {
                "ref": "#feed",
                "type": "ref"
              }
            },
            "links": {
              "ref": "#links",
              "type": "ref"
            }
          }
        },
        "encoding": "application/json"
      },
      "description": "Get information about a feed generator, including policies and offered feed URIs. Does not require auth; implemented by Feed Generator services (not App View)."
    },
    "links": {
      "type": "object",
      "properties": {
        "privacyPolicy": {
          "type": "string"
        },
        "termsOfService": {
          "type": "string"
        }
      }
    }
  },
  "$type": "com.atproto.lexicon.schema",
  "lexicon": 1
}